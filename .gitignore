# Environment variables — NEVER commit these
.env
.env.local
.env.production

# Node
node_modules/
npm-debug.log*
package-lock.json

# Netlify
.netlify/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Build artifacts
dist/
build/

# Logs
*.log
logs/
