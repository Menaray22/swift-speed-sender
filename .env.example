# ============================================================
# SWIFT SPEED SENDER — ENVIRONMENT VARIABLES
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file and rename the copy to: .env
# 2. Fill in every value below
# 3. NEVER commit .env to GitHub — it is in .gitignore
# 4. Also add all these variables in Netlify:
#    Site Settings → Environment Variables → Add variable
# ============================================================

# ------ SUPABASE ------
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
# WARNING: NEVER put this key in any frontend JS file
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------ EMAIL (for contact form notifications) ------
# Option A: Use Gmail App Password (recommended for small scale)
# Go to: Google Account → Security → App Passwords → Generate
EMAIL_FROM=noreply@swiftspeedsender.com
EMAIL_TO=your-personal-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Option B: Use SendGrid (better for more volume)
# SENDGRID_API_KEY=your-sendgrid-key

# ------ SITE ------
SITE_URL=https://swiftspeedsender.netlify.app
# Change to your custom domain once connected:
# SITE_URL=https://www.swiftspeedsender.com

# ------ ADMIN ------
# This is the email you will use to log into the admin panel
# Create this user in: Supabase → Authentication → Users → Add User
ADMIN_EMAIL=admin@swiftspeedsender.com
